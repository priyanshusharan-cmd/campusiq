{
  "expo": {
    "name": "CampusIQ",
    "slug": "campusiq",
    "version": "1.0.0",
    "icon": "./assets/images/campusiq-icon.png",
    "orientation": "portrait",
    "scheme": "campusiq",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.priyanshusharan.campusiq"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.campusiq"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/campusiq-icon.png"
    },
    "plugins": [
      "./strip-push-plugin.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#181424",
          "image": "./assets/images/campusiq-icon-transparent.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}