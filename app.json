{
  "expo": {
    "name": "CampusIQ",
    "slug": "campusiq",
    "version": "1.0.0",
    "icon": "./assets/images/campusiq-icon-transparent.png",
    "orientation": "portrait",
    "scheme": "campusiq",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.priyanshusharan.campusiq",
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.priyanshusharan.campusiq"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/campusiq-icon-transparent.png"
    },
    "plugins": [
      "./strip-push-plugin.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#181424",
          "image": "./assets/images/campusiq-icon-transparent.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow CampusIQ to use Face ID to unlock your app."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
